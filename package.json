{
  "name": "modular-mind-map",
  "version": "1.0.0",
  "description": "AI-based mind map application",
  "main": "server.js",
  "bin": {
    "mindmap": "./cli/mindmap-cli.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "predev:all": "node generate-certs.js && npx kill-port 3000 --silent || true",
    "dev:all": "concurrently -n API,UI -c cyan,magenta \"npm run dev\" \"cd frontend && npm run dev\"",
    "build:ui": "cd frontend && npm run build"
  },
  "keywords": [
    "mind-map",
    "project-management",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "selfsigned": "^5.5.0",
    "uuid": "^9.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "concurrently": "^10.0.0",
    "nodemon": "^3.0.1"
  }
}
